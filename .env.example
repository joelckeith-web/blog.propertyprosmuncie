# ──────────────────────────────────────────────
# Property Pros Blog — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────────────

# Anthropic API — for blog content generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# GitHub — for committing blog posts directly to main
GITHUB_TOKEN=ghp_xxxxx
GITHUB_OWNER=joelckeith-web
GITHUB_REPO=blog.propertyprosmuncie
GITHUB_BRANCH=main

# Site config
NEXT_PUBLIC_SITE_URL=https://blog.propertyprosmuncie.com
NEXT_PUBLIC_MAIN_SITE_URL=https://www.propertyprosmuncie.com

# Cron secret (Vercel cron authorization)
CRON_SECRET=your-cron-secret-here

# ──────────────────────────────────────────────
# OPTIONAL: Google Indexing API
# Enables automatic index pinging after each post is published.
# Requires a Google Cloud service account with Indexing API enabled.
# The service account email must be added as an owner in Search Console.
# ──────────────────────────────────────────────
# GOOGLE_INDEXING_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
