# ──────────────────────────────────────────────
# Property Pros Blog — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────────────

# Anthropic API — for blog content generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# GitHub — for committing blog drafts to dev branch
GITHUB_TOKEN=ghp_xxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=property-pros-blog
GITHUB_BRANCH=dev

# Site config
NEXT_PUBLIC_SITE_URL=https://blog.propertyprosmuncie.com
NEXT_PUBLIC_MAIN_SITE_URL=https://www.propertyprosmuncie.com

# Cron secret (Vercel cron authorization)
CRON_SECRET=your-cron-secret-here

# Optional: Resend — for notification emails when drafts are ready
# RESEND_API_KEY=re_xxxxx
# NOTIFICATION_EMAIL=approver@propertyprosmuncie.com
